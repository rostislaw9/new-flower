generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  pending
  contacted
  approved
  rejected
  completed
}

model Appointment {
  id                 String            @id @default(cuid())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  fullName           String
  email              String
  contactMethod      String
  phone              String?
  tattooDescription  String
  bodyPlacement      String?
  tattooSize         String?
  preferredDates     String[]
  budgetRange        String?
  referenceImages    String[]
  status             AppointmentStatus @default(pending)

  @@index([status, createdAt])
  @@index([email])
  @@index([createdAt])
  @@map("appointments")
}

model GalleryItem {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  title        String
  description  String?
  imageUrl     String
  category     String
  featured     Boolean  @default(false)
  displayOrder Int      @default(0)
  width        Int      @default(800)
  height       Int      @default(600)

  @@map("gallery_items")
}

model Review {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  clientName String
  clientEmail String?
  rating     Int
  text       String
  featured   Boolean  @default(false)
  visible    Boolean  @default(false)

  @@map("reviews")
  @@index([featured, createdAt])
  @@index([visible, createdAt])
  @@index([rating])
}

model AboutBio {
  id          String                @id @default(cuid())
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  translations AboutBioTranslation[]

  @@map("about_bios")
}

model AboutBioTranslation {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bioId       String
  bio         AboutBio @relation(fields: [bioId], references: [id], onDelete: Cascade)
  locale      String
  title       String
  description String

  @@unique([bioId, locale])
  @@map("about_bio_translations")
  @@index([bioId, locale])
}

model AboutJourney {
  id           String                    @id @default(cuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  displayOrder Int                       @default(0)
  year         String
  translations AboutJourneyTranslation[]

  @@map("about_journeys")
  @@index([displayOrder])
}

model AboutJourneyTranslation {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  journeyId   String
  journey     AboutJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  locale      String
  title       String
  description String

  @@unique([journeyId, locale])
  @@map("about_journey_translations")
  @@index([journeyId, locale])
}

model FaqGroup {
  id          String                @id @default(cuid())
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  displayOrder Int                  @default(0)
  questions   FaqQuestion[]
  translations FaqGroupTranslation[]

  @@map("faq_groups")
  @@index([displayOrder])
}

model FaqGroupTranslation {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  groupId     String
  group       FaqGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  locale      String
  title       String

  @@unique([groupId, locale])
  @@map("faq_group_translations")
  @@index([groupId, locale])
}

model FaqQuestion {
  id          String           @id @default(cuid())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  groupId     String
  group       FaqGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  displayOrder Int             @default(0)
  translations FaqTranslation[]

  @@map("faq_questions")
  @@index([groupId, displayOrder])
}

model FaqTranslation {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  questionId  String
  question    FaqQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  locale      String
  questionText String
  answerText  String

  @@unique([questionId, locale])
  @@map("faq_translations")
  @@index([questionId, locale])
}
