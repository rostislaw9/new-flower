generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  pending
  contacted
  approved
  rejected
  completed
}

model Appointment {
  id                 String            @id @default(cuid())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  fullName           String
  email              String
  contactMethod      String
  phone              String?
  tattooDescription  String
  bodyPlacement      String?
  tattooSize         String?
  preferredDates     String[]
  budgetRange        String?
  referenceImages    String[]
  status             AppointmentStatus @default(pending)

  @@index([status, createdAt])
  @@index([email])
  @@index([createdAt])
  @@map("appointments")
}

model PortfolioItem {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  title        String
  description  String?
  imageUrl     String
  category     String
  featured     Boolean  @default(false)
  displayOrder Int      @default(0)
  width        Int      @default(800)
  height       Int      @default(600)

  @@map("portfolio_items")
}

model Review {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  clientName String
  clientEmail String?
  rating     Int
  text       String
  featured   Boolean  @default(false)

  @@map("reviews")
  @@index([featured, createdAt])
  @@index([rating])
}

model FaqGroup {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  title       String
  displayOrder Int          @default(0)
  questions   FaqQuestion[]

  @@map("faq_groups")
  @@index([displayOrder])
}

model FaqQuestion {
  id          String           @id @default(cuid())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  groupId     String
  group       FaqGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  displayOrder Int             @default(0)
  translations FaqTranslation[]

  @@map("faq_questions")
  @@index([groupId, displayOrder])
}

model FaqTranslation {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  questionId  String
  question    FaqQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  locale      String
  questionText String
  answerText  String

  @@unique([questionId, locale])
  @@map("faq_translations")
  @@index([questionId, locale])
}
